# Copy these into `.env` (or merge with existing Supabase vars) for integration tests.
# Never commit real service-role keys to git.

# Enable integration test suite
SUPABASE_IT=1

# Test accounts — run `npm run seed:test-users` to create in Supabase Auth
SUPABASE_TEST_USER_EMAIL=nestbean-test-user@mailinator.com
SUPABASE_TEST_USER_PASSWORD=NestbeanTestUser1!

SUPABASE_TEST_ADMIN_EMAIL=nestbean-test-admin@mailinator.com
SUPABASE_TEST_ADMIN_PASSWORD=NestbeanTestAdmin1!

# Required (same as app — see .env.example)
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-publishable-key

# Required only for seed:test-users (server-side only — never expose in frontend)
# SUPABASE_SECRET_KEY=your-service-role-key
